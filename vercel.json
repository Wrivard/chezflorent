{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm -w run vercel-build",
  "outputDirectory": "public",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/menu", "destination": "/menu/index.html" },
    { "source": "/a-propos", "destination": "/a-propos/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/evenements", "destination": "/evenements/index.html" },
    { "source": "/groupes", "destination": "/groupes/index.html" },
    { "source": "/confidentialite", "destination": "/confidentialite/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
